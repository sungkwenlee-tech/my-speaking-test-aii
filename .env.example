OPENAI_API_KEY=

# Supabase: Dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# 서버 전용 (절대 클라이언트에 노출 금지). Dashboard → API → service_role
# DB 자동 테스트(/api/db/test) 및 관리용. 로그인 사용자 RLS 통과에는 anon+세션 사용.
SUPABASE_SERVICE_ROLE_KEY=

# Ollama HTTP API (선택). Netlify 서버에서는 localhost Ollama에 접근할 수 없음.
# 배포 후 무료 음성 모드를 쓰려면 공개 URL이 있는 Ollama 프록시를 두거나, OpenAI Realtime만 사용.
# OLLAMA_BASE_URL=https://your-ollama-host.example.com

# Netlify: Site configuration → Environment variables 에 위 키들을 동일 이름으로 등록
